{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rCleaner",
  "version": "0.1.0",
  "identifier": "app.rseries.rcleaner",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:1436",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "rCleaner",
        "width": 1320,
        "height": 860,
        "minWidth": 860,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
